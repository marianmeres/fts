# PostgreSQL connection used by the test suite (`deno task test` → `deno test --env-file`).
# The test database must exist; the suite creates/drops its own table inside it.
# Required extensions (btree_gin, pg_trgm) must be installed by a superuser if the
# TEST_PG_USER role lacks CREATE privilege (see AGENTS.md / manageExtensions option).
TEST_PG_HOST=localhost
TEST_PG_PORT=5432
TEST_PG_DATABASE=test_fts
TEST_PG_USER=dbuser
TEST_PG_PASSWORD=

# PostgreSQL connection used by the example app (`deno task example`).
# The database must exist (it is NOT auto-created) — see example/README.md.
EXAMPLE_PG_HOST=localhost
EXAMPLE_PG_PORT=5432
EXAMPLE_PG_DATABASE=fts_movies
EXAMPLE_PG_USER=dbuser
EXAMPLE_PG_PASSWORD=
